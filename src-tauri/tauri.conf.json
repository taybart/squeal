{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "squeal",
  "version": "0.1.0",
  "identifier": "com.taylor.squeal",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "squeal",
        "width": 800,
        "height": 600
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 500,
        "height": 600,
        "visible": false,
        "url": "settings.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
